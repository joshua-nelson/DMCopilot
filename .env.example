# Copy to .env.local for local development.
# Phase 0 WP3 (Auth) requires Clerk keys for sign-in/sign-up to function.

# Public app URL (used for absolute URLs in metadata/emails later)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Clerk (Auth)
# Create an app in Clerk and copy the keys from the dashboard.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Optional but recommended: keep redirects explicit.
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/onboarding"

# --- Future integrations (placeholders; not required for WP1) ---

# AI / voice / bot services (server-only)
ANTHROPIC_API_KEY="sk-ant-..."
VOYAGE_API_KEY="voy-..."
DEEPGRAM_API_KEY="dg-..."
ELEVENLABS_API_KEY="elevenlabs-..."

# Flux image generation provider (pick one later)
REPLICATE_API_TOKEN="r8_..."
FAL_KEY="fal_..."

# Discord bot (server-only)
DISCORD_BOT_TOKEN="..."
DISCORD_CLIENT_ID="..."

# Supabase
# Public (safe to expose to browsers)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
# Server-only (never expose to browsers)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Redis (Upstash)
UPSTASH_REDIS_REST_URL="https://..."
UPSTASH_REDIS_REST_TOKEN="..."

# Observability
# Sentry
# Server-side DSN (errors from server/edge)
SENTRY_DSN=""
# Client-side DSN (embedded in browser bundle)
NEXT_PUBLIC_SENTRY_DSN=""

# Optional: enable Sentry source map upload during build (CI/CD)
# (Only required if you want readable stack traces in Sentry.)
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# PostHog (product analytics)
# Public browser key (embedded in client bundle)
NEXT_PUBLIC_POSTHOG_KEY=""
# Optional: self-hosted or EU cloud host
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"
